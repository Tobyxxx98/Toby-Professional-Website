<style>

:root{
    --bg:#0b0f19;
    --card:#121826;
    --card-hover:#1b2435;
    --primary:#4f8cff;
    --text:#ffffff;
    --muted:#9ca3af;
    --border:#232d40;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Inter',sans-serif;
    scroll-behavior:smooth;
}

body{
    background:var(--bg);
    color:var(--text);
}

.container{
    width:min(1200px,90%);
    margin:auto;
}

nav{
    position:fixed;
    top:0;
    width:100%;
    backdrop-filter:blur(12px);
    background:rgba(11,15,25,.85);
    border-bottom:1px solid var(--border);
    z-index:999;
}

.nav-container{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 0;
}

.logo{
    font-weight:800;
    font-size:1.2rem;
}

.nav-links{
    display:flex;
    gap:30px;
}

.nav-links a{
    color:white;
    text-decoration:none;
}

.hero{
    min-height:100vh;
    display:flex;
    align-items:center;
}

.hero-content{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:60px;
    align-items:center;
}

.hero h1{
    font-size:4rem;
    line-height:1.1;
}

.hero span{
    color:var(--primary);
}

.hero p{
    margin-top:25px;
    color:var(--muted);
    font-size:1.1rem;
}

.btn-group{
    margin-top:35px;
    display:flex;
    gap:15px;
}

.btn{
    padding:14px 28px;
    border-radius:10px;
    text-decoration:none;
    font-weight:600;
}

.primary{
    background:var(--primary);
    color:white;
}

.secondary{
    border:1px solid var(--border);
    color:white;
}

.hero-image{
    display:flex;
    justify-content:center;
}

.profile{
    width:380px;
    height:380px;
    border-radius:25px;
    background:linear-gradient(135deg,#4f8cff,#7c3aed);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:5rem;
    font-weight:800;
}

section{
    padding:100px 0;
}

.section-title{
    font-size:2.4rem;
    margin-bottom:20px;
}

.section-sub{
    color:var(--muted);
    margin-bottom:50px;
}

.stats{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
}

.stat-card{
    background:var(--card);
    border:1px solid var(--border);
    padding:30px;
    border-radius:20px;
}

.stat-card h3{
    font-size:2rem;
    color:var(--primary);
}

.skills{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.skill{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:20px;
    padding:25px;
}

.skill h3{
    margin-bottom:10px;
}

.skill p{
    color:var(--muted);
}

.projects{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(350px,1fr));
    gap:25px;
}

.project{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:20px;
    overflow:hidden;
    transition:.3s;
}

.project:hover{
    transform:translateY(-8px);
    background:var(--card-hover);
}

.project img{
    width:100%;
    height:250px;
    object-fit:cover;
}

.project-content{
    padding:25px;
}

.project-content h3{
    margin-bottom:10px;
}

.project-content p{
    color:var(--muted);
}

.timeline{
    display:flex;
    flex-direction:column;
    gap:20px;
}

.timeline-item{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:20px;
    padding:25px;
}

.contact-box{
    background:linear-gradient(135deg,#4f8cff,#7c3aed);
    padding:60px;
    border-radius:30px;
    text-align:center;
}

.contact-box h2{
    font-size:2rem;
}

.contact-box p{
    margin:20px 0;
}

footer{
    text-align:center;
    padding:40px 0;
    color:var(--muted);
}

@media(max-width:900px){

.hero-content{
    grid-template-columns:1fr;
}

.hero h1{
    font-size:3rem;
}

.profile{
    width:280px;
    height:280px;
}
}

</style>
</head>
